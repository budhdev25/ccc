# Phase 1 is mock-only. These wire up in later phases.
VITE_BACKEND_URL=http://localhost:3001

# Mock toggles (BUILD_PLAN §7.6) — two independent switches.
# Phase 2/3 read these to short-circuit the avatar / Glass pipeline.
VITE_USE_MOCK=true
VITE_USE_MOCK_TAVUS=true
VITE_USE_MOCK_GLASS=true

# NEVER put TAVUS_API_KEY / GLASS_API_KEY here — VITE_-prefixed vars are bundled
# to the client. Real keys live in server/.env only (PHI gate, BUILD_PLAN §7.7).
